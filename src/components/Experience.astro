---
import { Check, ArrowUpRight } from "@lucide/astro";
import type { ExperienceProps } from "../types";
import Section from "./Section.astro";
import TechBadge from "./TechBadge.astro";

interface Props {
  experience: ExperienceProps[];
}

const { experience } = Astro.props;

const pathname = Astro.url.pathname;
const lang = pathname.split("/")[1] || "en";
const currentLabel = lang === "es" ? "Actual" : "Current";
const currentValues = ["Present", "Actualidad"];
---

<Section text="Work Experience" textEs="Experiencia Laboral" href="experience">
  {
    experience.map(
      ({ company, position, startDate, endDate, summary, skills, link }) => {
        const isCurrent = currentValues.includes(endDate);
        return (
          <div class="experience-item relative mb-8 rounded-2xl border border-slate-200 bg-slate-50 p-6 transition-colors dark:border-neutral/20 dark:bg-[#1c232d]/60 md:p-7">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <h3 class="font-serif text-2xl font-semibold text-slate-900 dark:text-white">
                  {link ? (
                    <a
                      href={link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="group inline-flex items-center gap-1.5 transition-colors hover:text-primary"
                    >
                      {company}
                      <ArrowUpRight class="h-5 w-5 text-primary opacity-70 transition-opacity group-hover:opacity-100" />
                    </a>
                  ) : (
                    company
                  )}
                </h3>
                <h4 class="font-serif text-xl font-medium text-primary">
                  {position}
                </h4>
              </div>
              <div class="flex shrink-0 flex-col items-start gap-1.5 sm:items-end">
                {isCurrent && (
                  <span class="inline-flex items-center gap-1.5 rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-700 dark:bg-green-900/40 dark:text-green-300">
                    <span class="h-1.5 w-1.5 animate-pulse rounded-full bg-green-500" />
                    {currentLabel}
                  </span>
                )}
                <span class="text-sm text-slate-500 dark:text-white/70">
                  {startDate} — {endDate}
                </span>
              </div>
            </div>

            {Array.isArray(summary) ? (
              <ul class="mt-4 list-none space-y-3">
                {summary.map((log) => (
                  <li class="flex items-start gap-3 text-base text-slate-600 dark:text-neutral">
                    <Check class="mt-1 h-4 w-4 shrink-0 text-primary" />
                    <span>{log}</span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="mt-4 text-base text-slate-600 dark:text-neutral">
                {summary}
              </p>
            )}

            {skills && skills.length > 0 && (
              <div class="mt-5 flex flex-wrap gap-2">
                {skills.map((skill) => (
                  <TechBadge tech={skill} />
                ))}
              </div>
            )}
          </div>
        );
      }
    )
  }
</Section>
