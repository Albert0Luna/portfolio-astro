---
import { Image } from "astro:assets";
import type { AboutProps, HeroProps } from "../types";
import Section from "./Section.astro";

type Props = AboutProps & Pick<HeroProps, "name">;
const { image, name } = Astro.props;
---

<Section text="About Me" textEs="Sobre mí" href="about">
  <h3 class="text-2xl md:text-3xl font-bold text-white mb-6 md:mb-8">
    Hi! I'm Gustavo Alberto Robles Luna 👋
  </h3>
  <div
    class="flex flex-col items-center gap-12 md:flex-row md:gap-10 lg:gap-12"
  >
    <div
      class="w-full text-base text-slate-300 md:pr-6 about-description flex flex-col gap-6"
    >
      <div class="space-y-6">
        <p class="text-base md:text-lg leading-relaxed text-balance">
          I'm a <span
            class="font-bold text-blue-400 bg-blue-950/30 px-2 py-0.5 rounded"
            >Full-Stack JavaScript developer</span
          >, 23 years old, based in
          <span class="font-semibold text-blue-300">Querétaro, Mexico</span>.
          I'm studying <span class="font-semibold text-slate-200"
            >Computer Systems Engineering</span
          > (UVEG, GPA 9.0), but what truly drives me is my passion for programming.
        </p>

        <div
          class="bg-slate-900/50 border border-slate-800 rounded-lg p-5 md:p-6"
        >
          <h4
            class="text-lg font-bold text-blue-400 mb-4 flex items-center gap-2"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path
                d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"
              ></path>
            </svg>
            Certifications
          </h4>
          <ul class="space-y-2.5">
            <li class="flex items-start gap-2">
              <span class="text-blue-400 mt-1">▪</span>
              <a
                href="https://learn.mongodb.com/c/UhARMgERRzyn7bMzcpO_Zw"
                target="_blank"
                class="text-blue-300 hover:text-blue-200 underline-offset-2 hover:underline font-medium transition-colors"
                >MongoDB Node.js Developer Path</a
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-blue-400 mt-1">▪</span>
              <a
                href="https://www.credly.com/badges/f8049746-611a-4b20-8310-fe3a6c0f9168/public_url"
                target="_blank"
                class="text-blue-300 hover:text-blue-200 underline-offset-2 hover:underline font-medium transition-colors"
                >Advanced Schema Design</a
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-blue-400 mt-1">▪</span>
              <a
                href="https://www.credly.com/badges/01317c41-b90c-4362-9206-78c357ff36df/public_url"
                target="_blank"
                class="text-blue-300 hover:text-blue-200 underline-offset-2 hover:underline font-medium transition-colors"
                >GitHub Foundations</a
              >
            </li>
            <li class="flex items-start gap-2">
              <span class="text-blue-400 mt-1">▪</span>
              <a
                href="https://www.credly.com/badges/7709c02c-2a2c-428e-825b-655874a86f41/public_url"
                target="_blank"
                class="text-blue-300 hover:text-blue-200 underline-offset-2 hover:underline font-medium transition-colors"
                >AWS Cloud Practitioner</a
              >
            </li>
          </ul>
        </div>

        <div class="flex items-center gap-3 text-base md:text-lg">
          <span class="text-slate-400">🌐</span>
          <span class="text-slate-300">Languages:</span>
          <span
            class="font-semibold text-white bg-slate-800 px-3 py-1 rounded-full"
            >Spanish (Native)</span
          >
          <span
            class="font-semibold text-white bg-slate-800 px-3 py-1 rounded-full"
            >English (Advanced)</span
          >
        </div>

        <p
          class="text-base md:text-lg leading-relaxed font-semibold text-green-400 bg-green-950/30 border border-green-900/50 rounded-lg p-4 text-center"
        >
          ✨ Ready for new challenges and to create amazing solutions!
        </p>
      </div>
    </div>
    <div class="relative h-80 w-64 flex-shrink-0 about-photo">
      <div class="absolute inset-0 bg-blue-500/20 blur-2xl rounded-lg"></div>
      <div
        class="relative rotate-[5deg] bg-gradient-to-br from-white to-slate-100 p-4 md:rotate-[7deg] shadow-2xl"
      >
        <Image
          class="object-cover border-4 border-slate-200 shadow-xl"
          src={image}
          width="260"
          height="260"
          alt={name}
        />
      </div>
    </div>
  </div>
</Section>
