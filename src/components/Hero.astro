---
import type { HeroProps } from "../types/index";
type Props = HeroProps;

const {
  name,
  specialty,
  summary,
  email,
  buttonText,
  projectsButtonText = "View Projects",
} = Astro.props;
---

<section class="py-24 md:py-32 lg:py-40" id="#hero">
  <div class="relative">
    <div
      class="absolute -top-20 -left-20 w-72 h-72 bg-blue-500/20 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute -bottom-20 -right-20 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl"
    >
    </div>

    <div class="relative z-10">
      <h1
        class="mb-3 font-serif text-5xl font-bold tracking-tightest text-white sm:text-7xl md:text-8xl lg:text-9xl animate-[slide-in_0.6s_ease-out]"
      >
        {name}
      </h1>
      <p
        class="mb-6 md:mb-8 font-serif text-2xl leading-tight font-bold tracking-tighter text-blue-400 sm:text-4xl md:text-5xl lg:text-6xl animate-[slide-in_0.7s_ease-out]"
      >
        {specialty}
      </p>
      <p
        class="mb-8 md:mb-12 text-base md:text-lg lg:text-xl font-normal text-slate-300 leading-relaxed max-w-3xl animate-[slide-in_0.8s_ease-out]"
      >
        {summary}
      </p>

      <div class="flex flex-wrap gap-4 animate-[slide-in_0.9s_ease-out]">
        <a
          class="inline-flex items-center gap-2 rounded-full bg-blue-600 px-8 py-4 text-base font-semibold text-white shadow-lg shadow-blue-500/50 transition-all duration-300 hover:bg-blue-700 hover:shadow-xl hover:shadow-blue-500/60 hover:scale-105"
          href={`mailto:${email}`}
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          {buttonText}
        </a>

        <a
          class="inline-flex items-center gap-2 rounded-full border-2 border-slate-700 bg-transparent px-8 py-4 text-base font-semibold text-white transition-all duration-300 hover:border-blue-500 hover:bg-blue-500/10 hover:scale-105"
          href="#projects"
        >
          <svg
            class="w-5 h-5"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
          </svg>
          {projectsButtonText}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes slide-in {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
