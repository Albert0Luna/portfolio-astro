---
import { ArrowUpRight } from "@lucide/astro";
import type { SiteConfig } from "../types";

type Props = Pick<SiteConfig, "author" | "socialLinks">;

const { author, socialLinks } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer
  class="w-full border-t border-slate-200 dark:border-neutral/20 px-5 pt-5 pb-8 text-center text-slate-600 dark:text-white"
>
  <ul class="mb-5 flex flex-wrap justify-center gap-x-5 text-xs">
    {
      socialLinks.map(({ text, href }) => (
        <li>
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 px-4 py-3 hover:text-primary"
          >
            {text}
            <ArrowUpRight size={14} />
          </a>
        </li>
      ))
    }
  </ul>
  <p class="text-xs">
    {author} - {currentYear}
  </p>
</footer>
