---
import { ArrowUpRight, Github } from "@lucide/astro";
import type { ProjectProps } from "../types";
import Section from "./Section.astro";
import TechBadge from "./TechBadge.astro";
import { Image } from "astro:assets";

interface Props {
  projects: ProjectProps[];
}

const { projects } = Astro.props;
---

<Section text="Featured Projects" textEs="Proyectos Destacados" href="projects">
  <div class="projects-container">
    {
      projects.map(
        ({ name, summary, image, linkPreview, linkSource, stack }, index) => {
          return (
            <div class="project-item sticky mb-12 rounded-2xl border border-slate-200 dark:border-neutral/20 bg-white dark:bg-black">
              <div class="bg-difu relative z-[1] grid auto w-full grid-rows-2 overflow-hidden rounded-2xl bg-slate-50 dark:bg-[#1c232d]/85 sm:grid-cols-2 sm:grid-rows-1 md:h-96">
                <div class="px-6 pt-12">
                  <div>
                    <h3 class="mb-5 font-serif text-3xl font-medium text-primary">
                      {name}
                    </h3>
                  </div>
                  <p class="text-base text-slate-600 dark:text-neutral">{summary}</p>
                  <div class="mt-5 flex flex-wrap items-center gap-2">
                    {stack.map((item: string) => (
                      <TechBadge tech={item} />
                    ))}
                  </div>
                  <div class="flex gap-5 py-8 pl-1 text-slate-700 dark:text-white">
                    <a
                      href={linkPreview}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center gap-1 hover:text-primary hover:underline"
                    >
                      <span>Demo</span>
                      <ArrowUpRight size={22} />
                    </a>
                    {linkSource && (
                      <a
                        href={linkSource}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center gap-1 hover:text-primary hover:underline"
                      >
                        <span>Source</span>
                        <Github size={20} />
                      </a>
                    )}
                  </div>
                </div>
                <div class="flex items-end justify-end overflow-hidden">
                  <Image
                    class="h-full w-[95%] rounded-ss-xl rounded-ee-2xl object-none object-left-top sm:h-[85%] sm:w-full"
                    src={image}
                    alt={name}
                    width="736"
                    height="483"
                  />
                </div>
              </div>
            </div>
          );
        }
      )
    }
  </div>
</Section>
