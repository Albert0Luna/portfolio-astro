#!/usr/bin/env bash
set -euo pipefail

CHANGELOG_FILE="CHANGELOG.md"
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
RAG_DIFF_FILE="$REPO_ROOT/git.diff"
RAG_INDEXER="$REPO_ROOT/tools/rag/index.js"

if [ ! -f "$CHANGELOG_FILE" ]; then
  cat > "$CHANGELOG_FILE" <<'EOF'
# Changelog

Este archivo se genera automaticamente a partir de los commits.
EOF
fi

MSG="$(git log -1 --pretty=%B)"
TITLE="$(printf "%s" "$MSG" | head -n1)"
DATE="$(date +%Y-%m-%d)"
TICKET="$(printf "%s" "$MSG" | grep -oE '[A-Z]+-[0-9]+' | head -n1 || true)"

MOTIVO="$(printf "%s" "$MSG" | awk '
  BEGIN {capture=0}
  /^Motivo:/ {capture=1; sub(/^Motivo:[[:space:]]*/, ""); if (length($0)>0) print; next}
  /^[A-Za-z]+:/ {if (capture==1) capture=0}
  {if (capture==1) print}
')"

CAMBIOS="$(printf "%s" "$MSG" | awk '
  BEGIN {capture=0}
  /^Cambios:/ {capture=1; sub(/^Cambios:[[:space:]]*/, ""); if (length($0)>0) print; next}
  /^[A-Za-z]+:/ {if (capture==1) capture=0}
  {if (capture==1) print}
')"

if [ -z "$MOTIVO" ]; then
  MOTIVO="No especificado en el commit."
fi

if [ -z "$CAMBIOS" ]; then
  CAMBIOS="No especificado en el commit."
fi

{
  echo
  echo "## $DATE - $TITLE"
  if [ -n "$TICKET" ]; then
    echo "- Ticket: $TICKET"
  fi
  echo "- Motivo:"
  printf '%s\n' "$MOTIVO" | sed 's/^/- /'
  echo "- Cambios:"
  printf '%s\n' "$CAMBIOS" | sed 's/^/- /'
} >> "$CHANGELOG_FILE"

# Keep RAG index updated for the latest commit diff.
if [ -f "$RAG_INDEXER" ] && command -v node >/dev/null 2>&1; then
  if git rev-parse --verify HEAD~1 >/dev/null 2>&1; then
    git diff HEAD~1..HEAD > "$RAG_DIFF_FILE" || true
  else
    git diff HEAD > "$RAG_DIFF_FILE" || true
  fi

  node "$RAG_INDEXER" || true
fi
